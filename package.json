{
  "name": "nanobanana-ppt-studio",
  "version": "1.0.1",
  "productName": "PPTGEN",
  "description": "Local PPT workflow studio powered by Nano Banana, Gemini, GPT Image 2 and reusable PPT harness tooling.",
  "main": "electron-main.js",
  "bin": "server.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis --x64"
  },
  "pkg": {
    "scripts": [
      "server.js",
      "workflow-service.js",
      "scripts/**/*.js"
    ],
    "assets": [
      "public/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "build": {
    "appId": "com.pptgen.desktop",
    "asar": false,
    "directories": {
      "output": "../dist"
    },
    "files": [
      "electron-main.js",
      "server.js",
      "workflow-service.js",
      "package.json",
      "node_modules/**/*",
      "public/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/v2/assets/pptgen-icon.ico",
      "artifactName": "PPTGEN-${version}-x64.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  },
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "26.8.1"
  }
}
