{
  "name": "pptgen",
  "version": "1.0.0",
  "productName": "AI驱动演示文稿自动生成系统",
  "description": "Local PPT workflow studio powered by Nano Banana, Gemini, GPT Image 2 and reusable PPT harness tooling.",
  "main": "electron-main.js",
  "bin": "server.js",
  "scripts": {
    "start": "electron .",
    "start:desktop": "electron .",
    "start:server": "node server.js",
    "dist": "electron-builder --win nsis --x64",
    "build:desktop": "electron-builder --win nsis --x64"
  },
  "pkg": {
    "scripts": [
      "server.js",
      "workflow-service.js",
      "scripts/**/*.js"
    ],
    "assets": [
      "public/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "build": {
    "appId": "com.pptgen.desktop",
    "asar": false,
    "executableName": "AI驱动演示文稿自动生成系统V1.0",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "electron-main.js",
      "server.js",
      "workflow-service.js",
      "package.json",
      "node_modules/**/*",
      "public/**/*"
    ],
    "win": {
      "signAndEditExecutable": true,
      "target": [
        "nsis"
      ],
      "icon": "public/v2/assets/pptgen-icon.ico",
      "artifactName": "AI驱动演示文稿自动生成系统-V1.0-x64.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI驱动演示文稿自动生成系统",
      "deleteAppDataOnUninstall": false
    }
  },
  "license": "MIT",
  "dependencies": {
    "docx": "^9.6.1",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "26.8.1"
  }
}
